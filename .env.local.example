# Copy to .env.local and fill in values from Supabase → Settings → API

# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# anon / public / publishable key — NOT service_role
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Menu/recipe parsing (server-only, required for onboarding upload flow)
ANTHROPIC_API_KEY=
